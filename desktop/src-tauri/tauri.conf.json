{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Writer",
  "version": "0.1.0",
  "identifier": "me.a160v.writer",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Writer",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
