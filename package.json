{
  "name": "astro-git-cms",
  "description": "A headless, git-based CMS — plus an optional Astro starter theme. Writes to any GitHub or Forgejo/Codeberg repository. Static, mobile-friendly, fediverse- and ATProto-connected.",
  "type": "module",
  "version": "0.2.0",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "dev:admin": "vite --config vite.config.admin.ts",
    "build:admin": "vite build --config vite.config.admin.ts",
    "preview:admin": "vite preview --config vite.config.admin.ts",
    "check": "astro check",
    "test": "bun test",
    "deploy": "bash scripts/deploy.sh",
    "newsletter": "bun scripts/send-newsletter.ts"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^5.18.2",
    "marked": "^15.0.12",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@types/bun": "^1.3.14",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3",
    "vite": "^7.3.4"
  }
}
