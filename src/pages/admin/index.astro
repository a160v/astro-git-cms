---
import { SITE } from "~/config/site";
import { withBase } from "~/lib/url";
import "~/styles/global.css";
import "~/admin/admin.css";

// Hand the admin the site's identity so headless installs (which have no
// SITE config at build time) and this bundled install share one code path.
const cmsSite = {
  title: SITE.title,
  url: SITE.url,
  basePath: import.meta.env.BASE_URL,
};
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>Admin — {SITE.title}</title>
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Admin" />
  </head>
  <body>
    <div id="admin-app" aria-live="polite">
      <div class="admin-view">
        <p class="muted" style="padding-top: 2rem;">Loading admin…</p>
        <noscript><p>The admin needs JavaScript — it talks to your git repository from this browser.</p></noscript>
      </div>
    </div>
    <script is:inline define:vars={{ cmsSite }}>
      window.__CMS_SITE__ = cmsSite;
    </script>
    <script>
      import "~/admin/main";
    </script>
  </body>
</html>
